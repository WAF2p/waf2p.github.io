<script>
  (function () {
    try {
      var t = localStorage.getItem('theme');
      if (t === 'dark' || t === 'light') {
        document.documentElement.setAttribute('data-theme', t);
      }
    } catch (e) {}
  })();
</script>
<link rel="stylesheet" href="{{uiRootPath}}/css/waf-style.css">
<script defer src="https://unpkg.com/lucide@latest"></script>
<script src="{{uiRootPath}}/js/waf-docs.js" defer></script>
